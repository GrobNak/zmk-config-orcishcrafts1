/*
 * OrcishCrafts1 Unified Layout & Matrix Transform Profile
 * Matches 6x4 Grid per side + 3 Inner Thumb Keys per Half (54 Live Keys)
 */

#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    /* CHOSEN COMPILER ANCHOR LAYER */
    chosen {
        zmk,physical-layout = &physical_layout_orcishcrafts1;
    };

    /* TRANSLATION TRANSFORM PROFILE MAP */
    matrix_transform0: matrix_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <5>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
            RC(4,3) RC(4,4) RC(4,5) RC(4,6) RC(4,7) RC(4,8)
        >;
    };

    /* PHYSICAL VIEWPORT INTERFACE BOUNDS FOR ZMK STUDIO */
    physical_layout_orcishcrafts1: physical_layout_orcishcrafts1 {
        compatible = "zmk,physical-layout";
        display-name = "OrcishCrafts1";
        transform = <&matrix_transform0>;

        keys 
            /* ================= LEFT SIDE MATRIX INDEXES ================= */
            = <&key_physical_attrs 100 100    0   50       0     0    50> // ESC  -> RC(0,0)
            , <&key_physical_attrs 100 100  100   37       0   100    37> // Q    -> RC(0,1)
            , <&key_physical_attrs 100 100  200   12       0   200    12> // W    -> RC(0,2)
            , <&key_physical_attrs 100 100  300    0       0   300     0> // E    -> RC(0,3)
            , <&key_physical_attrs 100 100  400   12       0   400    12> // R    -> RC(0,4)
            , <&key_physical_attrs 100 100  500   25       0   500    25> // T    -> RC(0,5)
            
            , <&key_physical_attrs 100 100    0  150       0     0   150> // TAB  -> RC(1,0)
            , <&key_physical_attrs 100 100  100  137       0   100   137> // A    -> RC(1,1)
            , <&key_physical_attrs 100 100  200  112       0   200   112> // S    -> RC(1,2)
            , <&key_physical_attrs 100 100  300  100       0   300   100> // D    -> RC(1,3)
            , <&key_physical_attrs 100 100  400  112       0   400   112> // F    -> RC(1,4)
            , <&key_physical_attrs 100 100  500  125       0   500   125> // G    -> RC(1,5)
            
            , <&key_physical_attrs 100 100    0  250       0     0   250> // LSHFT-> RC(2,0)
            , <&key_physical_attrs 100 100  100  237       0   100   237> // Z    -> RC(2,1)
            , <&key_physical_attrs 100 100  200  212       0   200   212> // X    -> RC(2,2)
            , <&key_physical_attrs 100 100  300  200       0   300   200> // C    -> RC(2,3)
            , <&key_physical_attrs 100 100  400  212       0   400   212> // V    -> RC(2,4)
            , <&key_physical_attrs 100 100  500  225       0   500   225> // B    -> RC(2,5)
            
            , <&key_physical_attrs 100 100    0  350       0     0   350> // LCTRL-> RC(3,0)
            , <&key_physical_attrs 100 100  100  337       0   100   337> // LGUI -> RC(3,1)
            , <&key_physical_attrs 100 100  200  312       0   200   312> // LALT -> RC(3,2)
            , <&key_physical_attrs 100 100  300  300       0   300   300> // N1   -> RC(3,3)
            , <&key_physical_attrs 100 100  400  312       0   400   312> // N2   -> RC(3,4)
            , <&key_physical_attrs 100 100  500  350       0   500   350> // N3   -> RC(3,5)
            
            , <&key_physical_attrs 100 100  400  437       0   400   437> // LBKT -> RC(4,3)
            , <&key_physical_attrs 100 100  500  465       0   500   465> // RBKT -> RC(4,4)
            , <&key_physical_attrs 100 100  600  450       0   600   450> // SPACE-> RC(4,5)

            /* ================= RIGHT SIDE MATRIX INDEXES ================= */
            , <&key_physical_attrs 100 100 1050   25       0  1050    25> // Y    -> RC(0,6)
            , <&key_physical_attrs 100 100 1150   12       0  1150    12> // U    -> RC(0,7)
            , <&key_physical_attrs 100 100 1250    0       0  1250     0> // I    -> RC(0,8)
            , <&key_physical_attrs 100 100 1350   12       0  1350    12> // O    -> RC(0,9)
            , <&key_physical_attrs 100 100 1450   37       0  1450    37> // P    -> RC(0,10)
            , <&key_physical_attrs 100 100 1550   50       0  1550    50> // BSPC -> RC(0,11)
            
            , <&key_physical_attrs 100 100 1050  125       0  1050   125> // H    -> RC(1,6)
            , <&key_physical_attrs 100 100 1150  112       0  1150   112> // J    -> RC(1,7)
            , <&key_physical_attrs 100 100 1250  100       0  1250   100> // K    -> RC(1,8)
            , <&key_physical_attrs 100 100 1350  112       0  1350   112> // L    -> RC(1,9)
            , <&key_physical_attrs 100 100 1450  137       0  1450   137> // SEMI -> RC(1,10)
            , <&key_physical_attrs 100 100 1550  150       0  1550   150> // SQT  -> RC(1,11)
            
            , <&key_physical_attrs 100 100 1050  225       0  1050   225> // N    -> RC(2,6)
            , <&key_physical_attrs 100 100 1150  212       0  1150   212> // M    -> RC(2,7)
            , <&key_physical_attrs 100 100 1250  200       0  1250   200> // COMMA-> RC(2,8)
            , <&key_physical_attrs 100 100 1350  212       0  1350   212> // DOT  -> RC(2,9)
            , <&key_physical_attrs 100 100 1450  237       0  1450   237> // FSLH -> RC(2,10)
            , <&key_physical_attrs 100 100 1550  250       0  1550   250> // RET  -> RC(2,11)
            
            , <&key_physical_attrs 100 100 1050  350       0  1050   350> // N4   -> RC(3,6)
            , <&key_physical_attrs 100 100 1150  312       0  1150   312> // N5   -> RC(3,7)
            , <&key_physical_attrs 100 100 1250  300       0  1250   300> // N6   -> RC(3,8)
            , <&key_physical_attrs 100 100 1350  312       0  1350   312> // MINUS-> RC(3,9)
            , <&key_physical_attrs 100 100 1450  337       0  1450   337> // EQUAL-> RC(3,10)
            , <&key_physical_attrs 100 100 1550  350       0  1550   350> // BSLH -> RC(3,11)
            
            , <&key_physical_attrs 100 100  950  450       0   950   450> // SPACE-> RC(4,6)
            , <&key_physical_attrs 100 100 1050  465       0  1050   465> // LALT -> RC(4,7)
            , <&key_physical_attrs 100 100 1150  440       0  1150   440> // RALT -> RC(4,8)
            ;
    };
};

&uicr {
    nfct-pins-as-gpios;
};
