/*
 * OrcishCrafts1 Unified ZMK Studio Production Profile
 * Features Dual-Transform Architecture to handle Split Offsets natively
 */

#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    /* CHOSEN COMPILER SYSTEM ANCHOR */
    chosen {
        zmk,physical-layout = &physical_layout_orcishcrafts1;
    };

    /* LEFT MASTER MATRIX MAPPING (Columns 0 to 5) */
    matrix_transform0: matrix_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <5>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
            RC(4,3) RC(4,4) RC(4,5)
        >;
    };

    /* RIGHT SATELLITE MATRIX MAPPING (Shifts Columns 0-5 straight to 6-11) */
    matrix_transform1: matrix_transform1 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <5>;
        col-offset = <6>; // <--- THE SHIFT VALVE: Strips the mirror loop completely
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
            RC(4,3) RC(4,4) RC(4,5)
        >;
    };

    /* PHYSICAL GEOMETRIC VIEWPORT DEFINITIONS FOR ZMK STUDIO */
    physical_layout_orcishcrafts1: physical_layout_orcishcrafts1 {
        compatible = "zmk,physical-layout";
        display-name = "OrcishCrafts1";
        
        /* REQUIRED SYSTEM FALLBACK: Satisfies the devicetree property rules */
        transform = <&matrix_transform0>;

        keys 
            /* ================= LEFT SIDE MATRIX TARGETS ================= */
            = <&key_physical_attrs 100 100    0   50       0     0    50 &matrix_transform0> // ESC
            , <&key_physical_attrs 100 100  100   37       0   100    37 &matrix_transform0> // Q
            , <&key_physical_attrs 100 100  200   12       0   200    12 &matrix_transform0> // W
            , <&key_physical_attrs 100 100  300    0       0   300     0 &matrix_transform0> // E
            , <&key_physical_attrs 100 100  400   12       0   400    12 &matrix_transform0> // R
            , <&key_physical_attrs 100 100  500   25       0   500    25 &matrix_transform0> // T
            
            , <&key_physical_attrs 100 100    0  150       0     0   150 &matrix_transform0> // TAB
            , <&key_physical_attrs 100 100  100  137       0   100   137 &matrix_transform0> // A
            , <&key_physical_attrs 100 100  200  112       0   200   112 &matrix_transform0> // S
            , <&key_physical_attrs 100 100  300  100       0   300   100 &matrix_transform0> // D
            , <&key_physical_attrs 100 100  400  112       0   400   112 &matrix_transform0> // F
            , <&key_physical_attrs 100 100  500  125       0   500   125 &matrix_transform0> // G
            
            , <&key_physical_attrs 100 100    0  250       0     0   250 &matrix_transform0> // LSHFT
            , <&key_physical_attrs 100 100  100  237       0   100   237 &matrix_transform0> // Z
            , <&key_physical_attrs 100 100  200  212       0   200   212 &matrix_transform0> // X
            , <&key_physical_attrs 100 100  300  200       0   300   200 &matrix_transform0> // C
            , <&key_physical_attrs 100 100  400  212       0   400   212 &matrix_transform0> // V
            , <&key_physical_attrs 100 100  500  225       0   500   225 &matrix_transform0> // B
            
            , <&key_physical_attrs 100 100    0  350       0     0   350 &matrix_transform0> // LCTRL
            , <&key_physical_attrs 100 100  100  337       0   100   337 &matrix_transform0> // LGUI
            , <&key_physical_attrs 100 100  200  312       0   200   312 &matrix_transform0> // LALT
            , <&key_physical_attrs 100 100  300  300       0   300   300 &matrix_transform0> // N1
            , <&key_physical_attrs 100 100  400  312       0   400   312 &matrix_transform0> // N2
            , <&key_physical_attrs 100 100  500  350       0   500   350 &matrix_transform0> // N3
            
            , <&key_physical_attrs 100 100  400  437       0   400   437 &matrix_transform0> // LBKT
            , <&key_physical_attrs 100 100  500  465       0   500   465 &matrix_transform0> // RBKT
            , <&key_physical_attrs 100 100  600  450       0   600   450 &matrix_transform0> // SPACE

            /* ================= RIGHT SIDE MATRIX TARGETS ================= */
            , <&key_physical_attrs 100 100 1050   25       0  1050    25 &matrix_transform1> // Y
            , <&key_physical_attrs 100 100 1150   12       0  1150    12 &matrix_transform1> // U
            , <&key_physical_attrs 100 100 1250    0       0  1250     0 &matrix_transform1> // I
            , <&key_physical_attrs 100 100 1350   12       0  1350    12 &matrix_transform1> // O
            , <&key_physical_attrs 100 100 1450   37       0  1450    37 &matrix_transform1> // P
            , <&key_physical_attrs 100 100 1550   50       0  1550    50 &matrix_transform1> // BSPC
            
            , <&key_physical_attrs 100 100 1050  125       0  1050   125 &matrix_transform1> // H
            , <&key_physical_attrs 100 100 1150  112       0  1150   112 &matrix_transform1> // J
            , <&key_physical_attrs 100 100 1250  100       0  1250   100 &matrix_transform1> // K
            , <&key_physical_attrs 100 100 1350  112       0  1350   112 &matrix_transform1> // L
            , <&key_physical_attrs 100 100 1450  137       0  1450   137 &matrix_transform1> // SEMI
            , <&key_physical_attrs 100 100 1550  150       0  1550   150 &matrix_transform1> // SQT
            
            , <&key_physical_attrs 100 100 1050  225       0  1050   225 &matrix_transform1> // N
            , <&key_physical_attrs 100 100 1150  212       0  1150   212 &matrix_transform1> // M
            , <&key_physical_attrs 100 100 1250  200       0  1250   200 &matrix_transform1> // COMMA
            , <&key_physical_attrs 100 100 1350  212       0  1350   212 &matrix_transform1> // DOT
            , <&key_physical_attrs 100 100 1450  237       0  1450   237 &matrix_transform1> // FSLH
            , <&key_physical_attrs 100 100 1550  250       0  1550   250 &matrix_transform1> // RET
            
            , <&key_physical_attrs 100 100 1050  350       0  1050   350 &matrix_transform1> // N4
            , <&key_physical_attrs 100 100 1150  312       0  1150   312 &matrix_transform1> // N5
            , <&key_physical_attrs 100 100 1250  300       0  1250   300 &matrix_transform1> // N6
            , <&key_physical_attrs 100 100 1350  312       0  1350   312 &matrix_transform1> // MINUS
            , <&key_physical_attrs 100 100 1450  337       0  1450   337 &matrix_transform1> // EQUAL
            , <&key_physical_attrs 100 100 1550  350       0  1550   350 &matrix_transform1> // BSLH
            
            , <&key_physical_attrs 100 100  950  450       0   950   450 &matrix_transform1> // SPACE
            , <&key_physical_attrs 100 100 1050  465       0  1050   465 &matrix_transform1> // LALT
            , <&key_physical_attrs 100 100 1150  440       0  1150   440 &matrix_transform1> // RALT
            ;
    };
};

&uicr {
    nfct-pins-as-gpios;
};
