/*
 * OrcishCrafts1 Unified Layout & Matrix Transform Profile
 * Matches 6x4 Grid per side + 3 Inner Thumb Keys per Half (54 Total)
 */

#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    /* 1. CORE SYSTEM ASSIGNMENT: Links the keyboard straight to the layout schema below */
    chosen {
        zmk,physical-layout = &physical_layout_orcishcrafts1;
    };

    /* 2. TRANSLATION MATRIX TRANSFORM MAP (YOUR UNCHANGED BASELINE) */
    matrix_transform0: matrix_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <5>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
            RC(4,3) RC(4,4) RC(4,5) RC(4,6) RC(4,7) RC(4,8)
        >;
    };

    /* 3. PHYSICAL GEOMETRIC VIEWPORT DEFINITIONS FOR ZMK STUDIO USER INTERFACE */
    physical_layout_orcishcrafts1: physical_layout_orcishcrafts1 {
        compatible = "zmk,physical-layout";
        display-name = "OrcishCrafts1";
        
        /* THE CRITICAL LINK: Connects this block natively to the transform right above it */
        transform = <&matrix_transform0>;

        keys 
            /* ================= LEFT SIDE MATRIX (Keys 0 to 26) ================= */
            /* ROW 1: 6 Keys */
            = <&key_physical_attrs 100 100    0   50       0     0    50> // 0
            , <&key_physical_attrs 100 100  100   37       0   100    37> // 1
            , <&key_physical_attrs 100 100  200   12       0   200    12> // 2
            , <&key_physical_attrs 100 100  300    0       0   300     0> // 3
            , <&key_physical_attrs 100 100  400   12       0   400    12> // 4
            , <&key_physical_attrs 100 100  500   25       0   500    25> // 5
            
            /* ROW 2: 6 Keys */
            , <&key_physical_attrs 100 100    0  150       0     0   150> // 6
            , <&key_physical_attrs 100 100  100  137       0   100   137> // 7
            , <&key_physical_attrs 100 100  200  112       0   200   112> // 8
            , <&key_physical_attrs 100 100  300  100       0   300   100> // 9
            , <&key_physical_attrs 100 100  400  112       0   400   112> // 10
            , <&key_physical_attrs 100 100  500  125       0   500   125> // 11
            
            /* ROW 3: 6 Keys */
            , <&key_physical_attrs 100 100    0  250       0     0   250> // 12
            , <&key_physical_attrs 100 100  100  237       0   100   237> // 13
            , <&key_physical_attrs 100 100  200  212       0   200   212> // 14
            , <&key_physical_attrs 100 100  300  200       0   300   200> // 15
            , <&key_physical_attrs 100 100  400  212       0   400   212> // 16
            , <&key_physical_attrs 100 100  500  225       0   500   225> // 17
            
            /* ROW 4: 6 Keys */
            , <&key_physical_attrs 100 100    0  350       0     0   350> // 18
            , <&key_physical_attrs 100 100  100  337       0   100   337> // 19
            , <&key_physical_attrs 100 100  200  312       0   200   312> // 20
            , <&key_physical_attrs 100 100  300  300       0   300   300> // 21
            , <&key_physical_attrs 100 100  400  312       0   400   312> // 22
            , <&key_physical_attrs 100 100  500  350       0   500   350> // 23
            
            /* ROW 5 (LEFT THUMBS): 3 Keys */
            , <&key_physical_attrs 100 100  400  437       0   400   437> // 24
            , <&key_physical_attrs 100 100  500  465       0   500   465> // 25
            , <&key_physical_attrs 100 100  600  450       0   600   450> // 26

            /* ================= RIGHT SIDE MATRIX (Keys 27 to 53) ================= */
            /* ROW 1: 6 Keys */
            , <&key_physical_attrs 100 100 1050   25       0  1050    25> // 27
            , <&key_physical_attrs 100 100 1150   12       0  1150    12> // 28
            , <&key_physical_attrs 100 100 1250    0       0  1250     0> // 29
            , <&key_physical_attrs 100 100 1350   12       0  1350    12> // 30
            , <&key_physical_attrs 100 100 1450   37       0  1450    37> // 31
            , <&key_physical_attrs 100 100 1550   50       0  1550   50>  // 32
            
            /* ROW 2: 6 Keys */
            , <&key_physical_attrs 100 100 1050  125       0  1050   125> // 33
            , <&key_physical_attrs 100 100 1150  112       0  1150   112> // 34
            , <&key_physical_attrs 100 100 1250  100       0  1250   100> // 35
            , <&key_physical_attrs 100 100 1350  112       0  1350   112> // 36
            , <&key_physical_attrs 100 100 1450  137       0  1450   137> // 37
            , <&key_physical_attrs 100 100 1550  150       0  1550   150> // 38
            
            /* ROW 3: 6 Keys */
            , <&key_physical_attrs 100 100 1050  225       0  1050   225> // 39
            , <&key_physical_attrs 100 100 1150  212       0  1150   212> // 40
            , <&key_physical_attrs 100 100 1250  200       0  1250   200> // 41
            , <&key_physical_attrs 100 100 1350  212       0  1350   212> // 42
            , <&key_physical_attrs 100 100 1450  237       0  1450   237> // 43
            , <&key_physical_attrs 100 100 1550  250       0  1550   250> // 44
            
            /* ROW 4: 6 Keys */
            , <&key_physical_attrs 100 100 1050  350       0  1050   350> // 45
            , <&key_physical_attrs 100 100 1150  312       0  1150   312> // 46
            , <&key_physical_attrs 100 100 1250  300       0  1250   300> // 47
            , <&key_physical_attrs 100 100 1350  312       0  1350   312> // 48
            , <&key_physical_attrs 100 100 1450  337       0  1450   337> // 49
            , <&key_physical_attrs 100 100 1550  350       0  1550   350> // 50
            
            /* ROW 5 (RIGHT THUMBS): 3 Keys */
            , <&key_physical_attrs 100 100  950  450       0   950   450> // 51
            , <&key_physical_attrs 100 100 1050  465       0  1050   465> // 52
            , <&key_physical_attrs 100 100 1150  440       0  1150   440> // 53
            ;
    };
};

&uicr {
    nfct-pins-as-gpios;
};
