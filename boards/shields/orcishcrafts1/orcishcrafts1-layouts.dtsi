/*
 * OrcishCrafts1 Unified 54-Key Matrix Layout Definitions
 * Sequential indexing map unblocks ZMK Studio across all columns
 */

/ {
    /* 
       THE PHYSICAL WORKSPACE FIXED CORRELATION matrix:
       Maps your physical key bindings array chronologically (0 to 53) 
       to align with your exact devicetree matrix structure.
    */
    layouts {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        
        default_layout: default_layout {
            transform = <&matrix_transform0>;
            kscan = <&kscan0>;
            
            keys {
                /* ================= LEFT SIDE MATRIX (27 Keys: 0 to 26) ================= */
                /* ROW 1: 6 Keys */
                bindings = <&key_physical_attrs 100 100 0 0 0 0 0>
                           <&key_physical_attrs 100 100 1 0 0 0 0>
                           <&key_physical_attrs 100 100 2 0 0 0 0>
                           <&key_physical_attrs 100 100 3 0 0 0 0>
                           <&key_physical_attrs 100 100 4 0 0 0 0>
                           <&key_physical_attrs 100 100 5 0 0 0 0>
                /* ROW 2: 6 Keys */
                           <&key_physical_attrs 100 100 0 1 0 0 0>
                           <&key_physical_attrs 100 100 1 1 0 0 0>
                           <&key_physical_attrs 100 100 2 1 0 0 0>
                           <&key_physical_attrs 100 100 3 1 0 0 0>
                           <&key_physical_attrs 100 100 4 1 0 0 0>
                           <&key_physical_attrs 100 100 5 1 0 0 0>
                /* ROW 3: 6 Keys */
                           <&key_physical_attrs 100 100 0 2 0 0 0>
                           <&key_physical_attrs 100 100 1 2 0 0 0>
                           <&key_physical_attrs 100 100 2 2 0 0 0>
                           <&key_physical_attrs 100 100 3 2 0 0 0>
                           <&key_physical_attrs 100 100 4 2 0 0 0>
                           <&key_physical_attrs 100 100 5 2 0 0 0>
                /* ROW 4: 6 Keys */
                           <&key_physical_attrs 100 100 0 3 0 0 0>
                           <&key_physical_attrs 100 100 1 3 0 0 0>
                           <&key_physical_attrs 100 100 2 3 0 0 0>
                           <&key_physical_attrs 100 100 3 3 0 0 0>
                           <&key_physical_attrs 100 100 4 3 0 0 0>
                           <&key_physical_attrs 100 100 5 3 0 0 0>
                /* ROW 5: 3 Keys */
                           <&key_physical_attrs 100 100 3 4 0 0 0>
                           <&key_physical_attrs 100 100 4 4 0 0 0>
                           <&key_physical_attrs 100 100 5 4 0 0 0>

                /* ================= RIGHT SIDE MATRIX (27 Keys: 27 to 53) ================= */
                /* ROW 1: 6 Keys */
                           <&key_physical_attrs 100 100 6 0 0 0 0>
                           <&key_physical_attrs 100 100 7 0 0 0 0>
                           <&key_physical_attrs 100 100 8 0 0 0 0>
                           <&key_physical_attrs 100 100 9 0 0 0 0>
                           <&key_physical_attrs 100 100 10 0 0 0 0>
                           <&key_physical_attrs 100 100 11 0 0 0 0>
                /* ROW 2: 6 Keys */
                           <&key_physical_attrs 100 100 6 1 0 0 0>
                           <&key_physical_attrs 100 100 7 1 0 0 0>
                           <&key_physical_attrs 100 100 8 1 0 0 0>
                           <&key_physical_attrs 100 100 9 1 0 0 0>
                           <&key_physical_attrs 100 100 10 1 0 0 0>
                           <&key_physical_attrs 100 100 11 1 0 0 0>
                /* ROW 3: 6 Keys */
                           <&key_physical_attrs 100 100 6 2 0 0 0>
                           <&key_physical_attrs 100 100 7 2 0 0 0>
                           <&key_physical_attrs 100 100 8 2 0 0 0>
                           <&key_physical_attrs 100 100 9 2 0 0 0>
                           <&key_physical_attrs 100 100 10 2 0 0 0>
                           <&key_physical_attrs 100 100 11 2 0 0 0>
                /* ROW 4: 6 Keys */
                           <&key_physical_attrs 100 100 6 3 0 0 0>
                           <&key_physical_attrs 100 100 7 3 0 0 0>
                           <&key_physical_attrs 100 100 8 3 0 0 0>
                           <&key_physical_attrs 100 100 9 3 0 0 0>
                           <&key_physical_attrs 100 100 10 3 0 0 0>
                           <&key_physical_attrs 100 100 11 3 0 0 0>
                /* ROW 5: 3 Keys */
                           <&key_physical_attrs 100 100 6 4 0 0 0>
                           <&key_physical_attrs 100 100 7 4 0 0 0>
                           <&key_physical_attrs 100 100 8 4 0 0 0>;
            };
        };
    };
};
